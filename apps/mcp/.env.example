# Required
DATABASE_URL=your_postgres_connection_string

# Optional, defaults shown
MCP_BASE_URL=http://localhost:3010
WEB_ORIGIN=http://localhost:3000
API_URL=http://localhost:3001
MCP_PORT=3010
MCP_TOKEN_PEPPER=replace_with_at_least_32_random_chars_for_token_hashing

# Optional — hosted consumer MCP OAuth clients.
# ChatGPT defaults to chatgpt.com and validates /connector/oauth/* callbacks.
# Configure Claude/Gemini/other hosted redirect hosts once those apps provide their callback domains.
MCP_OAUTH_CHATGPT_REDIRECT_HOSTS=chatgpt.com
MCP_OAUTH_CLAUDE_REDIRECT_HOSTS=
MCP_OAUTH_GEMINI_REDIRECT_HOSTS=
MCP_OAUTH_CONSUMER_REDIRECT_HOSTS=

# Optional — rate limiting (Upstash Redis). Skip for local dev.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional — logging
AXIOM_TOKEN=
AXIOM_DATASET=