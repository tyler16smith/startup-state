{
	"extends": "../../packages/config/tsconfig.base.json",
	"compilerOptions": {
		"paths": {
			"~/*": ["./src/*"]
		},
		"incremental": true
	},
	"include": [
		"**/*.cjs",
		"**/*.js",
		"**/*.ts",
		"**/*.tsx",
		"next-env.d.ts",
		".next/types/**/*.ts"
	],
	"exclude": ["node_modules", "generated"]
}
