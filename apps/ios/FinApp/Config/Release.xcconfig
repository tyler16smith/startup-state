// Release configuration

// API Configuration
API_BASE_URL = https:\/\/api.example.com
WEB_BASE_URL = https:\/\/app.example.com

// App Configuration
PRODUCT_BUNDLE_IDENTIFIER = com.app.mobile

// Google Sign-In Configuration
