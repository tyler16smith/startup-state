{
	"name": "app",
	"private": true,
	"packageManager": "pnpm@8.10.0",
	"scripts": {
		"prepare": "git config core.hooksPath .githooks",
		"dev": "turbo dev",
		"build": "turbo run build",
		"lint": "turbo run check",
		"test": "pnpm --filter @app/api run test:api-contracts",
		"typecheck": "turbo run typecheck",
		"db:studio": "pnpm --filter @app/api run db:studio",
		"db:push": "pnpm --filter @app/api run db:push",
		"db:migrate": "pnpm --filter @app/api run db:migrate"
	},
	"devDependencies": {
		"turbo": "^1.12.4"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	]
}
