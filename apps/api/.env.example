# Since the ".env.local" file is gitignored, you can use this file to
# build a new ".env.local" file when you clone the repo for the API server.
# Keep this file up-to-date when you add new variables.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env.local" and populate it with your secrets.

# Node Environment
NODE_ENV="development"

# CORS - Web app origin for same-site subdomain requests
# Local dev: http://localhost:3000
# Production: set WEB_ORIGIN to your deployed web app URL.
# Optional comma-separated allowlist for extra browser origins.
CORS_ORIGINS=""
WEB_ORIGIN="http://localhost:3000"
APP_BASE_URL="http://localhost:3000"

# Prisma / Database
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/hackathon"

# NextAuth / Auth Configuration
# Generate a new secret: npx auth secret
AUTH_SECRET=""

# Shared secret for server-to-server calls between the web app and API
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_SECRET=""

# Google OAuth Provider (if using OAuth)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Encryption key for sensitive data (2FA secrets, etc.)
ENCRYPTION_KEY="encryption_key_here"

# Posthog
NEXT_PUBLIC_POSTHOG_KEY=public_token_here
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com

# Axiom
AXIOM_TOKEN=axiom_token_here
AXIOM_DATASET=dataset_name_here

# Resend (email service)
RESEND_API_KEY="api_key_here"
EMAIL_FROM="App <invites@mail.yourdomain.com>"

OPENAI_API_KEY=""
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# Optional but recommended for higher-quality RAG retrieval.
COHERE_API_KEY=""
COHERE_RERANK_MODEL="rerank-v3.5"
