# Since the ".env.local" file is gitignored, you can use this file to
# build a new ".env.local" file when you clone the repo for the web app.
# Keep this file up-to-date when you add new variables.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env.local" and populate it with your secrets.

# When adding additional environment variables, the schema in "src/env.js"
# should be updated accordingly.

# Next Auth
# Generate a new secret: npx auth secret
AUTH_SECRET=""

# Shared secret for server-to-server calls between the web app and API
# Must match INTERNAL_API_SECRET in the API app
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_SECRET=""

# Google OAuth Provider
# Create credentials at: https://console.developers.google.com/
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# REST API Server
# URL of the separate API server for REST calls
# Local dev: http://localhost:3001
# Production: set to your deployed API URL.
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Optional in production when sharing auth cookies across app/api subdomains.
AUTH_COOKIE_DOMAIN=""

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# Posthog
NEXT_PUBLIC_POSTHOG_KEY=public_token_here
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com

# Axiom
AXIOM_TOKEN=axiom_token_here
AXIOM_DATASET=dataset_name_here
