generator client {
  provider   = "prisma-client-js"
  engineType = "library"
  output     = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Auth models used by NextAuth and native/mobile bearer sessions.

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? @db.Text
  access_token             String? @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? @db.Text
  session_state            String?
  refresh_token_expires_in Int?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  username      String?   @unique
  password      String?

  trialStartedAt                     DateTime           @default(now())
  trialEndsAt                        DateTime           @default(dbgenerated("(now() + interval '30 days')"))
  subscriptionStatus                 SubscriptionStatus @default(NONE)
  subscriptionPlan                   SubscriptionPlan   @default(NONE)
  syncAccessStatus                   SyncAccessStatus   @default(ACTIVE)
  subscriptionCurrentPeriodStart     DateTime?
  subscriptionCurrentPeriodEnd       DateTime?
  subscriptionCancelAtPeriodEnd      Boolean            @default(false)
  subscriptionCanceledAt             DateTime?
  subscriptionProviderCustomerId     String?            @unique
  subscriptionProviderSubscriptionId String?            @unique
  subscriptionProviderPriceId        String?
  subscriptionLastWebhookEventId     String?
  subscriptionInterval               String?
  referralCode                       String?            @unique
  referredByUserId                   String?
  referralBonusDaysGranted           Int                @default(0)
  successfulReferralCount            Int                @default(0)

  twoFactorEnabled     Boolean @default(false)
  twoFactorSecret      String? @db.Text
  twoFactorBackupCodes String? @db.Text
  twoFactorVerified    Boolean @default(false)

  accounts                     Account[]
  sessions                     Session[]
  authSessions                 AuthSession[]
  settings                     UserSettings?
  demoOverlaySessions          DemoOverlaySession[]
  twoFactorTokens              TwoFactorToken[]
  refreshTokens                RefreshToken[]
  householdInvitesOwned        HouseholdInvite[]           @relation("HouseholdInviteOwner")
  householdMembershipsOwned    HouseholdMembership[]       @relation("HouseholdMembershipOwner")
  householdMembershipsAsMember HouseholdMembership[]       @relation("HouseholdMembershipMember")
  referredBy                   User?                       @relation("UserReferrals", fields: [referredByUserId], references: [id], onDelete: SetNull)
  referrals                    User[]                      @relation("UserReferrals")
  referralRedemptionsSent      ReferralRedemption[]        @relation("ReferralRedemptionsSent")
  referralRedemptionReceived   ReferralRedemption?         @relation("ReferralRedemptionReceived")
  agentConversations           AgentConversation[]
  mcpPersonalAccessTokens      McpPersonalAccessToken[]
  mcpOAuthAuthorizationCodes   McpOAuthAuthorizationCode[]
  mcpOAuthAccessTokens         McpOAuthAccessToken[]
  mcpToolCalls                 McpToolCall[]

  @@index([referredByUserId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TwoFactorToken {
  id      String   @id @default(cuid())
  userId  String
  token   String   @unique
  expires DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  sessionId  String?
  token      String    @unique
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
  deviceInfo String?   @db.Text

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  session AuthSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, revokedAt])
  @@index([sessionId])
  @@index([token])
  @@index([expiresAt])
}

model AuthSession {
  id           String    @id @default(cuid())
  userId       String
  createdAt    DateTime  @default(now())
  lastActiveAt DateTime  @default(now())
  expiresAt    DateTime
  revokedAt    DateTime?
  deviceInfo   String?   @db.Text
  ipAddress    String?

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@index([userId])
  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@index([lastActiveAt])
}

model UserSettings {
  id                            String   @id @default(cuid())
  userId                        String   @unique
  hasCompletedInitialOnboarding Boolean  @default(false)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DemoOverlaySession {
  id          String   @id @default(cuid())
  sessionKey  String   @unique
  userId      String?
  demoUserId  String
  isActive    Boolean  @default(true)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  uiStateJson Json?

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model HouseholdInvite {
  id           String                @id @default(cuid())
  ownerUserId  String
  inviteeName  String
  inviteeEmail String
  tokenHash    String
  status       HouseholdInviteStatus @default(PENDING)
  expiresAt    DateTime
  sentAt       DateTime?
  acceptedAt   DateTime?
  revokedAt    DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  ownerUser User @relation("HouseholdInviteOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@unique([tokenHash])
  @@index([ownerUserId, status, expiresAt])
  @@index([inviteeEmail])
}

model HouseholdMembership {
  id           String                    @id @default(cuid())
  ownerUserId  String
  memberUserId String
  status       HouseholdMembershipStatus @default(ACTIVE)
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  removedAt    DateTime?

  ownerUser  User @relation("HouseholdMembershipOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  memberUser User @relation("HouseholdMembershipMember", fields: [memberUserId], references: [id], onDelete: Cascade)

  @@unique([ownerUserId, memberUserId])
  @@index([ownerUserId])
  @@index([memberUserId])
}

model ReferralRedemption {
  id                  String   @id @default(cuid())
  referrerUserId      String
  referredUserId      String   @unique
  qualifiedAt         DateTime @default(now())
  bonusDaysToReferrer Int      @default(7)
  bonusDaysToReferred Int      @default(7)
  createdAt           DateTime @default(now())

  referrer User @relation("ReferralRedemptionsSent", fields: [referrerUserId], references: [id], onDelete: Cascade)
  referred User @relation("ReferralRedemptionReceived", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@index([referrerUserId])
}

model McpPersonalAccessToken {
  id          String    @id @default(cuid())
  userId      String
  name        String
  tokenPrefix String
  tokenHash   String    @unique
  scopes      String[]  @default([])
  clientName  String?
  expiresAt   DateTime?
  revokedAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolCalls McpToolCall[]

  @@index([userId])
  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@index([tokenHash])
}

model McpOAuthClient {
  id                String    @id @default(cuid())
  clientId          String    @unique
  clientSecretHash  String?
  name              String
  clientProfile     String
  redirectUris      String[]  @default([])
  scopes            String[]  @default([])
  grants            String[]  @default(["authorization_code", "refresh_token"])
  requestsPerMinute Int       @default(60)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  revokedAt         DateTime?

  authorizationCodes McpOAuthAuthorizationCode[]
  accessTokens       McpOAuthAccessToken[]
  toolCalls          McpToolCall[]

  @@index([clientProfile])
  @@index([revokedAt])
}

model McpOAuthAuthorizationCode {
  id                  String    @id @default(cuid())
  userId              String
  oauthClientId       String
  codeHash            String    @unique
  codeChallenge       String
  codeChallengeMethod String
  redirectUri         String
  scopes              String[]  @default([])
  expiresAt           DateTime
  consumedAt          DateTime?
  createdAt           DateTime  @default(now())
  ipAddress           String?
  userAgent           String?   @db.Text

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  oauthClient McpOAuthClient @relation(fields: [oauthClientId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([oauthClientId])
  @@index([expiresAt])
  @@index([consumedAt])
}

model McpOAuthAccessToken {
  id                    String    @id @default(cuid())
  userId                String
  oauthClientId         String
  tokenPrefix           String
  tokenHash             String    @unique
  refreshTokenHash      String?   @unique
  refreshTokenExpiresAt DateTime?
  scopes                String[]  @default([])
  expiresAt             DateTime
  revokedAt             DateTime?
  lastUsedAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  oauthClient McpOAuthClient @relation(fields: [oauthClientId], references: [id], onDelete: Cascade)
  toolCalls   McpToolCall[]

  @@index([userId])
  @@index([oauthClientId])
  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@index([refreshTokenExpiresAt])
  @@index([tokenHash])
}

model McpToolCall {
  id                    String   @id @default(cuid())
  userId                String?
  householdId           String?
  personalAccessTokenId String?
  oauthAccessTokenId    String?
  oauthClientId         String?
  clientName            String?
  clientProfile         String?
  toolName              String
  requiredScopes        String[] @default([])
  grantedScopes         String[] @default([])
  inputHash             String?
  inputSummary          Json?
  outputSummary         Json?
  status                String
  durationMs            Int
  errorCode             String?
  rateLimited           Boolean  @default(false)
  createdAt             DateTime @default(now())

  user                User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  personalAccessToken McpPersonalAccessToken? @relation(fields: [personalAccessTokenId], references: [id], onDelete: SetNull)
  oauthAccessToken    McpOAuthAccessToken?    @relation(fields: [oauthAccessTokenId], references: [id], onDelete: SetNull)
  oauthClient         McpOAuthClient?         @relation(fields: [oauthClientId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([personalAccessTokenId, createdAt])
  @@index([oauthAccessTokenId, createdAt])
  @@index([oauthClientId, createdAt])
  @@index([toolName, createdAt])
  @@index([status, createdAt])
}

model AgentConversation {
  id          String   @id @default(cuid())
  userId      String
  householdId String?
  title       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages       AgentMessage[]
  runs           AgentRun[]
  timelineBlocks AgentTimelineBlock[]
  widgetActions  AgentWidgetAction[]

  @@index([userId])
  @@index([householdId])
}

model AgentMessage {
  id             String           @id @default(cuid())
  conversationId String
  role           AgentMessageRole
  content        String           @db.Text
  metadata       Json?
  createdAt      DateTime         @default(now())

  conversation AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model AgentRun {
  id                    String         @id @default(cuid())
  conversationId        String
  userId                String
  householdId           String?
  clientRequestId       String?
  status                AgentRunStatus
  kind                  AgentRunKind   @default(chat)
  model                 String?
  provider              String?
  providerResponseId    String?
  promptVersion         String?
  agentVersion          String?
  toolRegistryVersion   String?
  streamProtocolVersion String?
  inputTokens           Int?
  outputTokens          Int?
  errorCode             String?
  errorMessage          String?        @db.Text
  createdAt             DateTime       @default(now())
  startedAt             DateTime?
  completedAt           DateTime?
  cancelledAt           DateTime?

  conversation   AgentConversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  steps          AgentRunStep[]
  toolCalls      AgentToolCall[]
  timelineBlocks AgentTimelineBlock[]
  widgetActions  AgentWidgetAction[]

  @@unique([userId, clientRequestId])
  @@index([conversationId])
  @@index([userId])
  @@index([householdId])
}

model AgentRunStep {
  id                 String             @id @default(cuid())
  runId              String
  stepIndex          Int
  type               AgentRunStepType
  status             AgentRunStepStatus
  providerResponseId String?
  input              Json?
  output             Json?
  errorCode          String?
  errorMessage       String?            @db.Text
  createdAt          DateTime           @default(now())
  completedAt        DateTime?

  run            AgentRun             @relation(fields: [runId], references: [id], onDelete: Cascade)
  toolCalls      AgentToolCall[]
  timelineBlocks AgentTimelineBlock[]
  widgetActions  AgentWidgetAction[]

  @@unique([runId, stepIndex])
  @@index([runId])
}

model AgentToolCall {
  id           String              @id @default(cuid())
  runId        String
  stepId       String?
  toolCallId   String
  toolName     String
  input        Json?
  output       Json?
  status       AgentToolCallStatus
  errorCode    String?
  errorMessage String?             @db.Text
  createdAt    DateTime            @default(now())
  completedAt  DateTime?

  run  AgentRun      @relation(fields: [runId], references: [id], onDelete: Cascade)
  step AgentRunStep? @relation(fields: [stepId], references: [id], onDelete: SetNull)

  @@unique([runId, toolCallId])
  @@index([runId])
  @@index([stepId])
  @@index([toolName])
}

model AgentTimelineBlock {
  id             String   @id @default(cuid())
  conversationId String
  runId          String?
  stepId         String?
  role           String
  type           String
  content        String?  @db.Text
  data           Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  run          AgentRun?         @relation(fields: [runId], references: [id], onDelete: SetNull)
  step         AgentRunStep?     @relation(fields: [stepId], references: [id], onDelete: SetNull)

  @@index([conversationId])
  @@index([runId])
  @@index([stepId])
}

model AgentWidgetAction {
  id              String    @id @default(cuid())
  conversationId  String
  widgetId        String
  runId           String?
  stepId          String?
  userId          String
  householdId     String?
  actionType      String
  input           Json
  output          Json?
  status          String
  clientRequestId String?
  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  conversation AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  run          AgentRun?         @relation(fields: [runId], references: [id], onDelete: SetNull)
  step         AgentRunStep?     @relation(fields: [stepId], references: [id], onDelete: SetNull)

  @@unique([widgetId, actionType, clientRequestId])
  @@index([conversationId])
  @@index([widgetId])
  @@index([userId])
  @@index([householdId])
  @@index([runId])
  @@index([stepId])
}

enum HouseholdInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum HouseholdMembershipStatus {
  ACTIVE
  REMOVED
}

enum SubscriptionStatus {
  NONE
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

enum SubscriptionPlan {
  NONE
  MONTHLY
  ANNUAL
}

enum SyncAccessStatus {
  ACTIVE
  PAUSED_TRIAL_EXPIRED
}

enum AgentMessageRole {
  user
  assistant
  system
  tool
}

enum AgentRunStatus {
  queued
  running
  completed
  failed
  cancelled
  waiting_for_user
}

enum AgentRunKind {
  chat
  widget_action
}

enum AgentRunStepType {
  model_response
  tool_execution
  user_input_required
}

enum AgentRunStepStatus {
  running
  completed
  failed
  cancelled
}

enum AgentToolCallStatus {
  running
  completed
  failed
  skipped
  cancelled
}
