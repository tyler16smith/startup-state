{
	"servers": {
		"startup-state-local": {
			"type": "stdio",
			"command": "pnpm",
			"args": ["--filter", "@app/mcp", "dev:stdio"],
			"env": {
				"FIN_MCP_TOKEN": "${env:FIN_MCP_TOKEN}",
				"DATABASE_URL": "${env:DATABASE_URL}",
				"MCP_TOKEN_PEPPER": "${env:MCP_TOKEN_PEPPER}"
			}
		},
		"startup-state-prod": {
			"command": "npx",
			"args": ["-y", "mcp-remote", "${env:STARTUP_STATE_MCP_URL}"]
		}
	}
}
