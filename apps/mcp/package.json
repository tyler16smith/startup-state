{
	"name": "@app/mcp",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev:http": "tsx src/server.ts --transport=http",
		"dev:stdio": "tsx src/server.ts --transport=stdio",
		"prebuild": "pnpm --filter @app/api exec prisma generate",
		"build": "rm -rf dist && tsc --project tsconfig.json && tsc-alias --project tsconfig.json --resolve-full-paths --resolve-full-extension .js && mkdir -p dist/apps/api && cp -R ../api/generated dist/apps/api/generated",
		"check": "biome check .",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf dist .turbo tsconfig.tsbuildinfo"
	},
	"dependencies": {
		"@axiomhq/js": "^1.6.0",
		"@app/mcp-contracts": "workspace:*",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@prisma/client": "^6.19.3",
		"@upstash/redis": "^1.35.3",
		"date-fns": "^4.1.0",
		"express": "^4.21.2",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.5",
		"@types/express": "^4.17.21",
		"@types/node": "^20.14.10",
		"tsc-alias": "^1.8.17",
		"tsx": "^4.21.0",
		"typescript": "^5.8.2"
	}
}
